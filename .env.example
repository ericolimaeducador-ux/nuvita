# Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nuvita

# JWT
JWT_ACCESS_SECRET=troque-este-segredo-em-producao-access
JWT_REFRESH_SECRET=troque-este-segredo-em-producao-refresh

# Redis
REDIS_URL=redis://localhost:6379

# Bcrypt e TOTP
BCRYPT_ROUNDS=12
TOTP_ISSUER=Nuvita

# Encriptacao de dados de pacientes (base64 de 32 bytes)
# gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PATIENT_DATA_ENCRYPTION_KEY=
PATIENT_DATA_HASH_KEY=

# Armazenamento de documentos (S3 ou Cloudflare R2)
DOCUMENT_STORAGE_BUCKET=nuvita-documentos
DOCUMENT_STORAGE_REGION=auto
DOCUMENT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
DOCUMENT_STORAGE_FORCE_PATH_STYLE=true
DOCUMENT_STORAGE_ACCESS_KEY_ID=
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=

# Email (resend ou sendgrid)
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@nuvita.com.br
RESEND_API_KEY=
# SENDGRID_API_KEY=

# WhatsApp (evolution ou zapi)
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolution.exemplo.com
EVOLUTION_INSTANCE=nuvita
EVOLUTION_API_KEY=
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+5511999999999

# Prontuario
PRONTUARIO_SIGNATURE_SECRET=

# Multitenancy
APP_ROOT_DOMAIN=nuvita.com.br
BOOTSTRAP_SECRET=troque-em-producao
