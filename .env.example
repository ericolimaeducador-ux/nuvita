# ============================================
# NUVITA API - Environment Configuration
# ============================================
# SECURITY NOTICE: Never commit actual secrets to git
# Use .env.local for development (add to .gitignore)
# Use Google Secret Manager in production
# Rotate secrets quarterly (HIPAA/LGPD requirement)
#

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/nuvita
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
BCRYPT_ROUNDS=12
TOTP_ISSUER=Nuvita

# ============================================
# PATIENT DATA ENCRYPTION (LGPD/HIPAA CRITICAL)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PATIENT_DATA_ENCRYPTION_KEY=your-base64-encoded-32-bytes-here
PATIENT_DATA_HASH_KEY=your-optional-base64-encoded-32-bytes

# ============================================
# DOCUMENT STORAGE (S3 or Cloudflare R2)
# ============================================
DOCUMENT_STORAGE_BUCKET=nuvita-documentos
DOCUMENT_STORAGE_REGION=auto
DOCUMENT_STORAGE_ENDPOINT=https://YOUR-ACCOUNT.r2.cloudflarestorage.com
DOCUMENT_STORAGE_FORCE_PATH_STYLE=true
DOCUMENT_STORAGE_ACCESS_KEY_ID=your-access-key-id
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================
# EMAIL NOTIFICATIONS
# ============================================
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@nuvita.com.br
RESEND_API_KEY=re_your_api_key_here

# ============================================
# WHATSAPP NOTIFICATIONS (Optional)
# ============================================
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolution.sua-empresa.com
EVOLUTION_INSTANCE=nuvita
EVOLUTION_API_KEY=your-evolution-api-key

# ============================================
# SMS NOTIFICATIONS (Optional)
# ============================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+5511999999999

# ============================================
# PRONTUÁRIO & MULTI-TENANCY
# ============================================
PRONTUARIO_SIGNATURE_SECRET=long-random-secret-for-digital-signatures
APP_ROOT_DOMAIN=nuvita.com.br
BOOTSTRAP_SECRET=change-in-production

# ============================================
# GOOGLE CLOUD PLATFORM (GCP)
# ============================================
GCP_PROJECT_ID=nuvita-499800
KMS_KEY_RING=nuvita-keyring
KMS_KEY=nuvita-master-key

# ============================================
# SECRETS MANAGER
# ============================================
# In production: gcp-secret-manager
# In development: local-env (this file)
SECRETS_BACKEND=local-env

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=debug
