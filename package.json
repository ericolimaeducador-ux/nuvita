    "gcp:rotate-secrets": "node scripts/rotate-secrets-worker.mjs"
  },
  "devDependencies": {
    "chalk": "^5.3.0",
    "mongodb": "^7.3.0"
  },
  "overrides": {
    "@nestjs/core": "10.4.22"
  }
}
